# ─── Bitstream Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Mezo Network ──────────────────────────────────────────────────────────────
MEZO_RPC_URL=https://rpc.matsnet.mezo.org
MEZO_CHAIN_ID=31611
MEZO_NETWORK=testnet

# ── Wallet / Keys ────────────────────────────────────────────────────────────
PRIVATE_KEY=                          # agent wallet private key (never user's key)
EXECUTOR_ADDRESS=
EXECUTOR_PRIVATE_KEY=                 # same as PRIVATE_KEY, used by backend executor

# ── Contract Addresses ────────────────────────────────────────────────────────
MUSD_CONTRACT_ADDRESS=
VAULT_CONTRACT_ADDRESS=
BITSTREAM_VAULT_ADDRESS=
PAYMENT_SCHEDULER_ADDRESS=
COLLATERAL_GUARD_ADDRESS=

# ── OpenAI (all AI agent features) ───────────────────────────────────────────
OPENAI_API_KEY=                       # GPT-4o for all agentic reasoning

# ── Redis (BullMQ job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend Agent ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── x402 Protocol ────────────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_DEMO_MODE=true
X402_SKIP_VALIDATION=false
X402_SPENDING_CAPS={}                 # JSON: { "https://endpoint": 10.00 }

# ── Blockchain explorers / data ───────────────────────────────────────────────
ALCHEMY_API_KEY=                      # for EVM wallet analysis
ETHERSCAN_API_KEY=                    # for Etherscan tx proxy
BITCOIN_API_URL=https://blockstream.info/api   # for BTC address analysis

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # from @BotFather

# ── WhatsApp Bot ──────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=                       # Meta Cloud API token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=                # any string you choose

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Bitstream
NEXT_PUBLIC_MEZO_NETWORK=testnet
NEXT_PUBLIC_MEZO_CHAIN_ID=31611
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_MAINNET_RPC=https://rpc.mezo.org
NEXT_PUBLIC_TESTNET_RPC=https://rpc.matsnet.mezo.org
NEXT_PUBLIC_MAINNET_EXPLORER=https://explorer.mezo.org
NEXT_PUBLIC_TESTNET_EXPLORER=https://explorer.matsnet.mezo.org
