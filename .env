# ─── Bitstream Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Mezo Network ──────────────────────────────────────────────────────────────
MEZO_RPC_URL=
MEZO_CHAIN_ID=31611
MEZO_NETWORK=testnet

# ── Wallet / Keys ────────────────────────────────────────────────────────────
PRIVATE_KEY=
EXECUTOR_ADDRESS=

# ── Contract Addresses ────────────────────────────────────────────────────────
MUSD_CONTRACT_ADDRESS=
VAULT_CONTRACT_ADDRESS=
BITSTREAM_VAULT_ADDRESS=
PAYMENT_SCHEDULER_ADDRESS=
COLLATERAL_GUARD_ADDRESS=

# ── Backend Agent ─────────────────────────────────────────────────────────────
PORT=4000
REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=info

# ── x402 Protocol ────────────────────────────────────────────────────────────
X402_DEMO_MODE=true
X402_SKIP_VALIDATION=false

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Bitstream
NEXT_PUBLIC_MEZO_NETWORK=testnet
NEXT_PUBLIC_MEZO_CHAIN_ID=31611
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
